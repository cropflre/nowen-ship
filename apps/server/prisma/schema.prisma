generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== 项目 =====
model Project {
  id                String        @id @default(cuid())
  name              String
  repoFullName      String        @unique @map("repo_full_name")
  defaultBranch     String        @default("main") @map("default_branch")
  projectType       String        @map("project_type")
  workflowFile      String        @map("workflow_file")
  buildInputsSchema Json?         @map("build_inputs_schema")
  isActive          Boolean       @default(true) @map("is_active")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  releasePlans   ReleasePlan[]
  releaseJobs    ReleaseJob[]
  githubReleases GithubRelease[]
  deployments    Deployment[]
  deployTargets  DeployTarget[]

  @@map("projects")
}

// ===== 发版计划 =====
model ReleasePlan {
  id              String      @id @default(cuid())
  projectId       String      @map("project_id")
  version         String
  tagName         String      @unique @map("tag_name")
  sourceBranch    String      @map("source_branch")
  sourceCommitSha String?     @map("source_commit_sha")
  changelog       String      @default("")
  releaseType     String      @map("release_type")
  status          String      @default("draft") @map("status")
  createdBy       String      @map("created_by")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  releaseJobs   ReleaseJob[]
  githubRelease GithubRelease?
  deployments   Deployment[]

  @@map("release_plans")
}

// ===== 构建任务 =====
model ReleaseJob {
  id             String      @id @default(cuid())
  releasePlanId  String?     @unique @map("release_plan_id")
  projectId      String      @map("project_id")
  githubRunId    BigInt      @unique @map("github_run_id")
  githubRunUrl   String      @map("github_run_url")
  workflowFile   String      @map("workflow_file")
  status         String
  conclusion     String?
  startedAt      DateTime?   @map("started_at")
  completedAt    DateTime?   @map("completed_at")
  rawPayload     Json?       @map("raw_payload")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  releasePlan ReleasePlan?    @relation(fields: [releasePlanId], references: [id], onDelete: Cascade)
  artifacts   ReleaseArtifact[]

  @@map("release_jobs")
}

// ===== 构建产物 =====
model ReleaseArtifact {
  id               String   @id @default(cuid())
  releaseJobId     String   @map("release_job_id")
  githubArtifactId BigInt   @unique @map("github_artifact_id")
  name             String
  fileName         String?  @map("file_name")
  sizeBytes        BigInt?  @map("size_bytes")
  platform         String?
  downloadUrl      String?  @map("download_url")
  expiresAt        DateTime? @map("expires_at")
  sha256           String?  @map("sha256")
  createdAt        DateTime @default(now()) @map("created_at")

  releaseJob ReleaseJob @relation(fields: [releaseJobId], references: [id], onDelete: Cascade)

  @@map("release_artifacts")
}

// ===== GitHub Release =====
model GithubRelease {
  id              String   @id @default(cuid())
  releasePlanId   String?  @unique @map("release_plan_id")
  projectId       String   @map("project_id")
  githubReleaseId Int      @unique @map("github_release_id")
  tagName         String   @map("tag_name")
  name            String?
  body            String?  @map("body")
  draft           Boolean  @default(true)
  prerelease      Boolean  @default(false)
  htmlUrl         String   @unique @map("html_url")
  createdAt       DateTime @default(now()) @map("created_at")
  publishedAt     DateTime? @map("published_at")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  releasePlan ReleasePlan? @relation(fields: [releasePlanId], references: [id], onDelete: Cascade)

  @@map("github_releases")
}

// ===== 部署目标 =====
model DeployTarget {
  id          String      @id @default(cuid())
  projectId   String      @map("project_id")
  name        String
  environment String
  type        String
  config      Json?
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployments Deployment[]

  @@map("deploy_targets")
}

// ===== 部署记录 =====
model Deployment {
  id             String   @id @default(cuid())
  projectId      String   @map("project_id")
  releasePlanId  String?  @map("release_plan_id")
  deployTargetId String   @map("deploy_target_id")
  version        String
  commitSha      String?  @map("commit_sha")
  status         String   @default("pending") @map("status")
  githubRunId    BigInt?  @unique @map("github_run_id")
  githubRunUrl   String?  @map("github_run_url")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  triggeredBy    String   @map("triggered_by")
  logs           String?
  createdAt      DateTime @default(now()) @map("created_at")

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  releasePlan  ReleasePlan?   @relation(fields: [releasePlanId], references: [id], onDelete: SetNull)
  deployTarget DeployTarget  @relation(fields: [deployTargetId], references: [id], onDelete: Cascade)

  @@map("deployments")
}

// ===== 审计日志 =====
model AuditLog {
  id         String   @id @default(cuid())
  actor      String
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  detail     String?
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([actor, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}
