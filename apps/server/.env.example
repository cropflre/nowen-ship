NODE_ENV=development
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL="postgresql://nowen:nowen_local_dev@localhost:5432/nowen_release_hub"

# Stage-1 uses a fine-grained PAT. SHIP-GITHUB-01 will replace this with GitHub App tokens.
# Required repository permissions: Contents read/write, Actions read/write, Releases read/write.
GITHUB_TOKEN=replace-with-a-fine-grained-token
GITHUB_TOKEN_TYPE=pat

# Temporary admin token for the MVP API. Use a long random value outside local development.
API_TOKEN=replace-with-a-long-random-value
