NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# PostgreSQL
DATABASE_URL="postgresql://nowen:nowen_local_dev@localhost:5432/nowen_release_hub"

# GitHub Personal Access Token (Fine-grained PAT recommended)
# Required scopes: contents:read/write, actions:read/write, releases:read/write
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin API Token (for frontend auth, simple Bearer token for MVP)
API_TOKEN=nowen-local-dev-token

# Log level
LOG_LEVEL=info
